from typing import Any

from ._operation import Operation as Operation
from .layout import Tree
from .tensor import Tensor

class GenericAddOperation(Operation):
    def forward(self, *inputs: Any) -> Tensor: ...
    def backward(self, gradient: Tensor) -> tuple[Tensor, Tensor]: ...

class GenericScalarMulOperation(Operation):
    def forward(self, *inputs: Any) -> Tensor: ...
    def backward(self, gradient: Tensor) -> tuple[Tensor]: ...

class GenericReduceSumOperation(Operation):
    def forward(self, *inputs: Any) -> Tensor: ...
    def backward(self, gradient: Tensor) -> tuple[Tensor]: ...

class GenericMatmulOperation(Operation):
    def forward(self, *inputs: Any) -> Tensor: ...
    def backward(self, gradient: Tensor) -> tuple[Tensor, Tensor]: ...

class RearrangeOperation(Operation):
    def forward(self, *inputs: Any) -> Tensor: ...
    def backward(self, gradient: Tensor) -> tuple[Tensor]: ...

class PermuteOperation(Operation):
    def forward(self, *inputs: Any) -> Tensor: ...
    def backward(self, gradient: Tensor) -> tuple[Tensor]: ...

def add(lhs: Tensor, rhs: Tensor) -> Tensor: ...
def mul(tensor: Tensor, scalar: Any) -> Tensor: ...
def reduce(tensor: Tensor) -> Tensor: ...
def matmul(lhs: Tensor, rhs: Tensor) -> Tensor: ...
def rearrange(
    tensor: Tensor, output: Tree, selection: Tree | None = None
) -> Tensor: ...
def permute(tensor: Tensor, *order: Any) -> Tensor: ...
