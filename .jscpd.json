{
  "path": ["src"],
  "threshold": 5.0,
  "reporters": ["console", "threshold"],
  "minLines": 5,
  "minTokens": 50,
  "mode": "mild",
  "ignore": [
    "**/tests/**",
    "**/test/**",
    "**/examples/**",
    "**/*.md",
    "**/*.mdx",
    "**/.github/**",
    "**/.beads/**",
    "**/.agents/**",
    "**/.codex/**",
    "**/.venv/**",
    "**/venv/**",
    "**/node_modules/**",
    "**/vendor/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/.ruff_cache/**",
    "**/.mypy_cache/**",
    "**/reports/**",
    "**/.jscpd/**",
    "**/generated/**",
    "**/*.generated.*",
    "**/build/**",
    "**/dist/**",
    "**/*.egg-info/**"
  ]
}
